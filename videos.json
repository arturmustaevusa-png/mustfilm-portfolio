  {
      category:  'Имидж',
      tag:       '#промышленность',
      image:     'https://static.tildacdn.com/tild6466-6632-4437-b630-653038613539/image.png',
      title:     'Имиджевый B2B-фильм: пять производств, 55 лет, тысяча специалистов',
